<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Quiz Inglés ECOEMS</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { font-family: Arial; background: #f0f0f0; margin: 0; padding: 20px; }
    .quiz { max-width: 800px; margin: auto; background: white; padding: 20px; border-radius: 10px; box-shadow: 0 0 10px rgba(0,0,0,0.2); }
    h1 { text-align: center; color: #2a5298; }
    .question { margin: 20px 0; }
    button { padding: 10px 20px; margin-top: 20px; }
    #result { margin-top: 20px; font-weight: bold; }
    canvas { margin-top: 30px; }
  </style>
</head>
<body>
  <div class="quiz">
    <h1>Quiz de Inglés - ECOEMS</h1>
    
    <div class="question">
      <p>1. Choose the correct past tense: "Yesterday I ___ to the park."</p>
      <label><input type="radio" name="q1" value="a"> go</label><br>
      <label><input type="radio" name="q1" value="b"> went</label><br>
      <label><input type="radio" name="q1" value="c"> gone</label>
    </div>

    <div class="question">
      <p>2. What is the synonym of "huge"?</p>
      <label><input type="radio" name="q2" value="a"> tiny</label><br>
      <label><input type="radio" name="q2" value="b"> enormous</label><br>
      <label><input type="radio" name="q2" value="c"> weak</label>
    </div>

    <div class="question">
      <p>3. Fill in the blank: "She has been studying ___ three hours."</p>
      <label><input type="radio" name="q3" value="a"> since</label><br>
      <label><input type="radio" name="q3" value="b"> for</label><br>
      <label><input type="radio" name="q3" value="c"> during</label>
    </div>

    <div class="question">
      <p>4. Reading comprehension: "If it rains tomorrow, we will cancel the trip."  
      What does this sentence mean?</p>
      <label><input type="radio" name="q4" value="a"> The trip is already canceled.</label><br>
      <label><input type="radio" name="q4" value="b"> The trip depends on the weather.</label><br>
      <label><input type="radio" name="q4" value="c"> The trip will happen no matter what.</label>
    </div>

    <button onclick="checkAnswers()">Enviar</button>
    <p id="result"></p>
    <canvas id="chart" width="400" height="200"></canvas>
  </div>

  <script>
    function checkAnswers() {
      let score = 0;
      let errors = {grammar:0, vocab:0, time:0, reading:0};

      // Respuestas correctas
      if(document.querySelector('input[name="q1"]:checked')?.value === "b") score++; else errors.grammar++;
      if(document.querySelector('input[name="q2"]:checked')?.value === "b") score++; else errors.vocab++;
      if(document.querySelector('input[name="q3"]:checked')?.value === "b") score++; else errors.time++;
      if(document.querySelector('input[name="q4"]:checked')?.value === "b") score++; else errors.reading++;

      document.getElementById("result").innerText = "Tu puntaje: " + score + "/4";

      // Gráfica
      const ctx = document.getElementById('chart').getContext('2d');
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: ['Gramática', 'Vocabulario', 'Tiempos verbales', 'Lectura'],
          datasets: [{
            label: 'Errores',
            data: [errors.grammar, errors.vocab, errors.time, errors.reading],
            backgroundColor: ['#e74c3c','#f39c12','#3498db','#2ecc71']
          }]
        },
        options: {
          responsive: true,
          scales: { y: { beginAtZero: true } }
        }
      });
    }
  </script>
</body>
</html>
